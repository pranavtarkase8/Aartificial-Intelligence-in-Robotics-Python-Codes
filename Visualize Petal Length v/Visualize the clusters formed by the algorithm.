import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler
import pandas as pd

# Sample dataset (replace with your data.csv if needed)
try:
    df = pd.read_csv("data.csv")
except:
    print("data.csv not found → using sample dataset")
    df = pd.DataFrame({
        'annual_income': [15, 16, 17, 18, 19, 20, 21, 22],
        'spending_score': [39, 81, 6, 77, 40, 76, 6, 94]
    })

# -------------------------------
# Select features
# -------------------------------
X = df[['annual_income', 'spending_score']]

# -------------------------------
# Standardize data
# -------------------------------
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# -------------------------------
# Apply K-Means
# -------------------------------
kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
clusters = kmeans.fit_predict(X_scaled)

df['Cluster'] = clusters

print(df)

# cluster visulization
plt.figure()

# Scatter plot for clusters
plt.scatter(
    X_scaled[:, 0],
    X_scaled[:, 1],
    c=clusters,
    cmap='viridis'
)

# Plot centroids
centroids = kmeans.cluster_centers_
plt.scatter(
    centroids[:, 0],
    centroids[:, 1],
    s=200,
    c='red',
    marker='X'
)

plt.title("Customer Clusters Visualization")
plt.xlabel("Annual Income (scaled)")
plt.ylabel("Spending Score (scaled)")

plt.show()
